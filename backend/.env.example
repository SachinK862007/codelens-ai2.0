# ──────────────────────────────────────────────────────────
#  CodeLens AI 2.0  —  Backend Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ──────────────────────────────────────────────────────────

# ── HuggingFace Inference API (FREE — no install required) ─
# Get a free token at https://huggingface.co (Settings → Access Tokens)
# With a free token you get higher rate limits than anonymous access.
HF_API_KEY=your_hf_token_here

# Best free model for code + chat — Mistral-7B-Instruct-v0.3
# Fast, real-time token streaming, free tier on HuggingFace Inference API
# No download, no GPU needed — runs on HuggingFace cloud
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# Generation Settings
# Temperature: 0.0 = precise/deterministic, 1.0 = creative/varied
AI_TEMPERATURE=0.2

# Max tokens per AI response (keep 512-1024 for free tier speed)
AI_MAX_TOKENS=1024
